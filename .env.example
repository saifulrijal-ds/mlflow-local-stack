# Postgres
POSTGRES_USER=mlflow
POSTGRES_PASSWORD=changeme
POSTGRES_DB=mlflow
POSTGRES_PORT=5432

# RustFS
RUSTFS_VERSION=latest
RUSTFS_ACCESS_KEY=rustfs
RUSTFS_SECRET_KEY=changeme
RUSTFS_HOST=rustfs
RUSTFS_API_PORT=9090
RUSTFS_CONSOLE_PORT=9091
RUSTFS_BUCKET=mlflow

# MLflow Server
MLFLOW_BACKEND_STORE_URI=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}
MLFLOW_ARTIFACTS_DESTINATION=s3://${RUSTFS_BUCKET}/
MLFLOW_S3_ENDPOINT_URL=http://${RUSTFS_HOST}:9000

# AWS region (for Boto3)
AWS_DEFAULT_REGION=us-east-1

# MLflow listen settings
MLFLOW_HOST=0.0.0.0
MLFLOW_PORT=5000

# MLflow version (e.g., 2.21.3 or "latest")
MLFLOW_VERSION=latest
